# Build artefacts
/bin/
/dist/
/pql
/pql.exe

# Test, coverage, profile output
*.test
*.out
*.prof
*.pprof
coverage.*
/tmp/

# Go module + workspace artefacts (we don't vendor; we don't use workspaces)
/vendor/
/go.work
/go.work.sum

# pql's own per-vault state. The project itself isn't a vault, but if
# anyone runs pql against the repo root (testing, dogfooding), .pql/
# lands here. Mirror what `pql init` writes to consumers' .gitignore:
# ignore everything except the planning snapshot and the replication
# changelog (D-15: per-table monthly SQL files that get committed and
# shared between replicas). .pql/hooks/ is per-clone state (T-28) —
# `pql init` plants it locally on every clone with the binary path
# baked in; tracking would produce per-developer drift.
.pql/*
!.pql/pql-plan.json
!.pql/changelog/

# SQLite index files should never land here, but defensive
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS cruft
.DS_Store
._*
Thumbs.db

# Secrets
.env
.env.local
.env.*.local

# Claude Code user-specific settings
.claude/settings.local.json

# pql shims planted by `pql init` into git's hooks dir. The shim is
# per-clone state (it bridges git's hooks dir to .pql/hooks/), and
# the hook scripts it sources are also per-clone (see T-28). Both
# get replanted on every `pql init`.
.githooks/pre-commit
.githooks/post-merge
