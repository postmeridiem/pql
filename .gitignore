# Build artefacts
/bin/
/dist/
/pql
/pql.exe

# Test, coverage, profile output
*.test
*.out
*.prof
*.pprof
coverage.*
/tmp/

# Go module + workspace artefacts (we don't vendor; we don't use workspaces)
/vendor/
/go.work
/go.work.sum

# pql's own per-vault state. The project itself isn't a vault, but if
# anyone runs pql against the repo root (testing, dogfooding), .pql/
# lands here. Mirror what `pql init` writes to consumers' .gitignore.
/.pql/

# SQLite index files should never land here, but defensive
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS cruft
.DS_Store
._*
Thumbs.db

# Secrets
.env
.env.local
.env.*.local

# Claude Code user-specific settings
.claude/settings.local.json
