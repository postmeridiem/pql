# Build artefacts
/bin/
/dist/
/pql
/pql.exe

# Test, coverage, profile output
*.test
*.out
*.prof
*.pprof
coverage.*
/tmp/

# Go module + workspace artefacts (we don't vendor; we don't use workspaces)
/vendor/
/go.work
/go.work.sum

# pql's own per-vault state. The project itself isn't a vault, but if
# anyone runs pql against the repo root (testing, dogfooding), .pql/
# lands here. Mirror what `pql init` writes to consumers' .gitignore:
# ignore everything except the planning snapshot, the in-tree hooks,
# and the replication changelog (D-15: per-table monthly SQL files
# that get committed and shared between replicas).
.pql/*
!.pql/pql-plan.json
!.pql/hooks/
!.pql/changelog/

# SQLite index files should never land here, but defensive
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm
*.db

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo

# OS cruft
.DS_Store
._*
Thumbs.db

# Secrets
.env
.env.local
.env.*.local

# Claude Code user-specific settings
.claude/settings.local.json

# pql shims planted by `pql init` into git's hooks dir. The shim is
# per-clone state (it bridges git's hooks dir to .pql/hooks/), so we
# track .pql/hooks/* (the actual scripts) and ignore the shim.
.githooks/pre-commit
.githooks/post-merge
